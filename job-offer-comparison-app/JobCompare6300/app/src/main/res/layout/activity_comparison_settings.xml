<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#8890BC"
        android:gravity="center"
        android:padding="16dp"
        android:text="JobCompare App"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Adjust Comparison Settings"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="10dp"/>

    <!-- Input Fields in Vertical Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Salary Weight -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Salary Weight"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputSalaryWeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="number"
                android:minHeight="48dp"
                android:textSize="16sp"
                android:text="1"
                android:textColor="#000000"
                android:hint="Enter 0-9" />
        </LinearLayout>

        <!-- Bonus Weight -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bonus Weight"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputBonusWeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="number"
                android:minHeight="48dp"
                android:textSize="16sp"
                android:text="1"
                android:textColor="#000000"
                android:hint="Enter 0-9" />
        </LinearLayout>

        <!-- Tuition Reimbursement -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tuition Reimbursement"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputTuitionWeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="number"
                android:minHeight="48dp"
                android:textSize="16sp"
                android:text="1"
                android:textColor="#000000"
                android:hint="Enter 0-9" />
        </LinearLayout>

        <!-- Health Insurance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Health Insurance"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputHealthInsuranceWeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="number"
                android:minHeight="48dp"
                android:textSize="16sp"
                android:text="1"
                android:textColor="#000000"
                android:hint="Enter 0-9" />
        </LinearLayout>

        <!-- Employee Discount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Employee Discount"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputEmployeeDiscountWeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="number"
                android:minHeight="48dp"
                android:textSize="16sp"
                android:text="1"
                android:textColor="#000000"
                android:hint="Enter 0-9" />
        </LinearLayout>

        <!-- Adoption Assistance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Adoption Assistance"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputAdoptionAssistanceWeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:inputType="number"
                android:minHeight="48dp"
                android:textSize="16sp"
                android:text="1"
                android:textColor="#000000"
                android:hint="Enter 0-9" />
        </LinearLayout>
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#8890BC"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:padding="12dp"/>

        <Button
            android:id="@+id/btnCancelSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#CCCCCC"
            android:text="Cancel"
            android:textColor="#000000"
            android:padding="12dp"/>
    </LinearLayout>

</LinearLayout>
