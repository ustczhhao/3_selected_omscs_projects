<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.ComparisonResultsActivity">

    <!-- Header -->
    <TextView
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#8890BC"
        android:gravity="center"
        android:padding="16dp"
        android:text="JobCompare App"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comparison Results"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Table for Job Comparison -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toTopOf="@id/backButton">

        <TableLayout
            android:id="@+id/comparisonTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:stretchColumns="1,2"
            android:background="#EEEEEE">

            <!-- Table Header -->
            <TableRow>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attribute"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:gravity="center"
                    android:background="#CCCCCC"/>

                <TextView
                    android:id="@+id/job1Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Job 1"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:gravity="center"
                    android:background="#CCCCCC"/>

                <TextView
                    android:id="@+id/job2Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Job 2"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:gravity="center"
                    android:background="#CCCCCC"/>
            </TableRow>

            <!-- Job Title -->
            <TableRow>
                <TextView android:text="Title:"/>
                <TextView android:id="@+id/job1TitleValue"/>
                <TextView android:id="@+id/job2TitleValue"/>
            </TableRow>

            <!-- Company -->
            <TableRow>
                <TextView android:text="Company:"/>
                <TextView android:id="@+id/job1CompanyValue"/>
                <TextView android:id="@+id/job2CompanyValue"/>
            </TableRow>

            <!-- Location -->
            <TableRow>
                <TextView android:text="City:"/>
                <TextView android:id="@+id/job1CityValue"/>
                <TextView android:id="@+id/job2CityValue"/>
            </TableRow>
            <TableRow>
                <TextView android:text="State:"/>
                <TextView android:id="@+id/job1StateValue"/>
                <TextView android:id="@+id/job2StateValue"/>
            </TableRow>

            <!-- Adjusted Salary -->
            <TableRow>
                <TextView android:text="Salary (Adjusted):"/>
                <TextView android:id="@+id/job1SalaryValue"/>
                <TextView android:id="@+id/job2SalaryValue"/>
            </TableRow>

            <!-- Adjusted Bonus -->
            <TableRow>
                <TextView android:text="Bonus (Adjusted):"/>
                <TextView android:id="@+id/job1BonusValue"/>
                <TextView android:id="@+id/job2BonusValue"/>
            </TableRow>

            <!-- Tuition Reimbursement -->
            <TableRow>
                <TextView android:text="Tuition Reimbursement:"/>
                <TextView android:id="@+id/job1TuitionValue"/>
                <TextView android:id="@+id/job2TuitionValue"/>
            </TableRow>

            <!-- Health Insurance -->
            <TableRow>
                <TextView android:text="Health Insurance:"/>
                <TextView android:id="@+id/job1InsuranceValue"/>
                <TextView android:id="@+id/job2InsuranceValue"/>
            </TableRow>

            <!-- Employee Discount -->
            <TableRow>
                <TextView android:text="Employee Discount:"/>
                <TextView android:id="@+id/job1DiscountValue"/>
                <TextView android:id="@+id/job2DiscountValue"/>
            </TableRow>

            <!-- Child Adoption Assistance -->
            <TableRow>
                <TextView android:text="Child Adoption Assistance:"/>
                <TextView android:id="@+id/job1AdoptionValue"/>
                <TextView android:id="@+id/job2AdoptionValue"/>
            </TableRow>

            <!-- Job Score -->
            <TableRow>
                <TextView android:text="Job Score:"/>
                <TextView android:id="@+id/job1ScoreValue"/>
                <TextView android:id="@+id/job2ScoreValue"/>
            </TableRow>

        </TableLayout>
    </ScrollView>

    <!-- Back Button -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Back to Job Selection"
        android:backgroundTint="#CCCCCC"
        android:textColor="#000000"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
